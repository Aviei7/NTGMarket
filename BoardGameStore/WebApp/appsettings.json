{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "Sqlite"
  },
  "Cache": {
    "Provider": "Memory"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=boardstore.db"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "JwtOptions": {
    "JwtCookieName": "bgs_at",
    "SecretKey": "secretkeysecretkeysecretkeysecretkeysecretkeysecretkeysecretkeysecretkey",
    "ExpiresHours": 12,
    "Path": "/",
    "HttpOnly": true,
    "Secure": true,
    "SameSite": "None"
  },
  "CartCookieOptions": {
    "TokenName": "guest_cart",
    "Path": "/",
    "HttpOnly": true,
    "Secure": true,
    "SameSite": "None",
    "ExpireDays": 30
  }
}
